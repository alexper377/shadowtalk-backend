# Copy this to .env and fill in your values

# PostgreSQL connection string (Railway gives you this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret for JWT tokens - change this to a random string!
JWT_SECRET=change-this-to-something-random-and-long-123

# Your frontend URL (for CORS)
CLIENT_URL=https://your-frontend.netlify.app

# Server port (Railway sets this automatically)
PORT=3001

# Environment
NODE_ENV=production
